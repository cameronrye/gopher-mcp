# Gopher & Gemini MCP Server Configuration
# Copy this file to .env and customize as needed.
#
# Only the variables listed here are read by the server. Gopher settings use
# the GOPHER_ prefix, Gemini settings use GEMINI_, and server settings have no
# prefix. Unknown variables are ignored.

# =============================================================================
# GOPHER PROTOCOL CONFIGURATION
# =============================================================================

# Maximum response size in bytes (default: 1048576 = 1MB)
GOPHER_MAX_RESPONSE_SIZE=1048576

# Request timeout in seconds (default: 30)
GOPHER_TIMEOUT_SECONDS=30

# Enable response caching (default: true)
GOPHER_CACHE_ENABLED=true

# Cache time-to-live in seconds (default: 300 = 5 minutes; max 86400)
GOPHER_CACHE_TTL_SECONDS=300

# Maximum number of cache entries (default: 1000)
GOPHER_MAX_CACHE_ENTRIES=1000

# Comma-separated list of allowed hosts (default: empty = all hosts allowed)
# Example: GOPHER_ALLOWED_HOSTS=gopher.floodgap.com,gopher.quux.org
GOPHER_ALLOWED_HOSTS=

# Allow connecting to loopback/private/internal addresses (default: false).
# Leave false in production; enabling it disables SSRF protection for Gopher.
GOPHER_ALLOW_LOCAL_HOSTS=false

# Maximum selector length in characters (default: 1024)
GOPHER_MAX_SELECTOR_LENGTH=1024

# Maximum search query length in characters (default: 256)
GOPHER_MAX_SEARCH_LENGTH=256

# =============================================================================
# GEMINI PROTOCOL CONFIGURATION
# =============================================================================

# Maximum response size in bytes (default: 1048576 = 1MB)
GEMINI_MAX_RESPONSE_SIZE=1048576

# Request timeout in seconds (default: 30)
GEMINI_TIMEOUT_SECONDS=30

# Enable response caching (default: true)
GEMINI_CACHE_ENABLED=true

# Cache time-to-live in seconds (default: 300 = 5 minutes; max 86400)
GEMINI_CACHE_TTL_SECONDS=300

# Maximum number of cache entries (default: 1000)
GEMINI_MAX_CACHE_ENTRIES=1000

# Comma-separated list of allowed hosts (default: empty = all hosts allowed)
# Example: GEMINI_ALLOWED_HOSTS=geminiprotocol.net,warmedal.se
GEMINI_ALLOWED_HOSTS=

# Allow connecting to loopback/private/internal addresses (default: false).
# Leave false in production; enabling it disables SSRF protection for Gemini.
GEMINI_ALLOW_LOCAL_HOSTS=false

# Enable TOFU (Trust-on-First-Use) certificate validation (default: true)
GEMINI_TOFU_ENABLED=true

# TOFU storage file path (default: ~/.gemini/tofu.json)
GEMINI_TOFU_STORAGE_PATH=

# Enable client certificate support (default: true)
GEMINI_CLIENT_CERTS_ENABLED=true

# Client certificate storage directory (default: ~/.gemini/certs/)
GEMINI_CLIENT_CERTS_STORAGE_PATH=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Log level (default: INFO). Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Emit structured (JSON) logs vs. console rendering (default: true)
STRUCTURED_LOGGING=true

# Log file path (optional). Logs always also go to stderr (never stdout, which
# carries the MCP protocol stream).
LOG_FILE_PATH=

# Enable development mode (default: false)
DEVELOPMENT_MODE=false
