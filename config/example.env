# Gopher & Gemini MCP Server Configuration
# Copy this file to .env and customize as needed.
#
# Only the variables listed here are read by the server. Gopher settings use the
# GOPHER_ prefix, Gemini settings use the GEMINI_ prefix, and server/logging
# settings use the GOPHER_MCP_ prefix. Unprefixed or unknown variables are ignored.

# =============================================================================
# GOPHER PROTOCOL CONFIGURATION
# =============================================================================

# Maximum response size in bytes (default: 1048576 = 1MB)
GOPHER_MAX_RESPONSE_SIZE=1048576

# Request timeout in seconds (default: 30)
GOPHER_TIMEOUT_SECONDS=30

# Enable response caching (default: true)
GOPHER_CACHE_ENABLED=true

# Cache time-to-live in seconds (default: 300 = 5 minutes; max 86400)
GOPHER_CACHE_TTL_SECONDS=300

# Maximum number of cache entries (default: 1000, LRU eviction)
GOPHER_MAX_CACHE_ENTRIES=1000

# Comma-separated list of allowed hosts (default: empty = all hosts allowed)
# Example: GOPHER_ALLOWED_HOSTS=gopher.floodgap.com,gopher.quux.org
GOPHER_ALLOWED_HOSTS=

# Allow connecting to loopback/private/internal addresses (default: false).
# Leave false in production; enabling it disables SSRF protection for Gopher.
GOPHER_ALLOW_LOCAL_HOSTS=false

# Optional positive port allowlist (comma-separated). When set, only these
# ports may be connected to, closing the arbitrary-port port-scanning gap.
# Empty = any non-dangerous port. Example: GOPHER_ALLOWED_PORTS=70
GOPHER_ALLOWED_PORTS=

# Maximum selector length in characters (default: 1024)
GOPHER_MAX_SELECTOR_LENGTH=1024

# Maximum search query length in characters (default: 256)
GOPHER_MAX_SEARCH_LENGTH=256

# Maximum characters of rendered text returned to the model (default: 50000).
# Responses longer than this are truncated and flagged.
GOPHER_MAX_RENDERED_CHARS=50000

# Maximum number of Gopher menu items returned to the model (default: 1000;
# 0 = unlimited). A large directory is truncated to this many items and flagged.
GOPHER_MAX_MENU_ITEMS=1000

# Per-host rate limit in requests per minute (default: 0 = disabled)
GOPHER_REQUESTS_PER_MINUTE=0

# Maximum concurrent requests (default: 0 = unlimited)
GOPHER_MAX_CONCURRENT_REQUESTS=0

# =============================================================================
# GEMINI PROTOCOL CONFIGURATION
# =============================================================================

# Maximum response size in bytes (default: 1048576 = 1MB)
GEMINI_MAX_RESPONSE_SIZE=1048576

# Request timeout in seconds (default: 30)
GEMINI_TIMEOUT_SECONDS=30

# Enable response caching (default: true)
GEMINI_CACHE_ENABLED=true

# Cache time-to-live in seconds (default: 300 = 5 minutes; max 86400)
GEMINI_CACHE_TTL_SECONDS=300

# Maximum number of cache entries (default: 1000, LRU eviction)
GEMINI_MAX_CACHE_ENTRIES=1000

# Comma-separated list of allowed hosts (default: empty = all hosts allowed)
# Example: GEMINI_ALLOWED_HOSTS=geminiprotocol.net,warmedal.se
GEMINI_ALLOWED_HOSTS=

# Allow connecting to loopback/private/internal addresses (default: false).
# Leave false in production; enabling it disables SSRF protection for Gemini.
GEMINI_ALLOW_LOCAL_HOSTS=false

# Optional positive port allowlist (comma-separated). When set, only these
# ports may be connected to, closing the arbitrary-port port-scanning gap.
# Empty = any non-dangerous port. Example: GEMINI_ALLOWED_PORTS=1965
GEMINI_ALLOWED_PORTS=

# Enable TOFU (Trust-on-First-Use) certificate validation (default: true)
GEMINI_TOFU_ENABLED=true

# TOFU storage file path (default: ~/.gemini/tofu.json)
GEMINI_TOFU_STORAGE_PATH=

# Reject certificates outside their validity window (default: false).
# When true, an expired or not-yet-valid certificate fails closed.
GEMINI_TOFU_REJECT_EXPIRED=false

# Enable automatic client certificate management (default: true)
GEMINI_CLIENT_CERTS_ENABLED=true

# Client certificate storage directory (default: ~/.gemini/certs/)
GEMINI_CLIENT_CERTS_STORAGE_PATH=

# Maximum characters of rendered text returned to the model (default: 50000).
# Responses longer than this are truncated and flagged.
GEMINI_MAX_RENDERED_CHARS=50000

# Per-host rate limit in requests per minute (default: 0 = disabled).
# Gemini status 44 SLOW_DOWN is always honoured regardless of this setting.
GEMINI_REQUESTS_PER_MINUTE=0

# Maximum concurrent requests (default: 0 = unlimited)
GEMINI_MAX_CONCURRENT_REQUESTS=0

# Comma-separated MIME types to deny (default: empty). Supports wildcards such
# as image/* . Example: GEMINI_DENIED_MIME_TYPES=image/*,application/octet-stream
GEMINI_DENIED_MIME_TYPES=

# =============================================================================
# SERVER CONFIGURATION (GOPHER_MCP_ prefix)
# =============================================================================

# Log level (default: INFO). Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
GOPHER_MCP_LOG_LEVEL=INFO

# Emit structured (JSON) logs vs. console rendering (default: true)
GOPHER_MCP_STRUCTURED_LOGGING=true

# Log file path (optional). Logs always go to stderr (never stdout, which
# carries the MCP protocol stream); set this to also tee them to a file.
GOPHER_MCP_LOG_FILE_PATH=
